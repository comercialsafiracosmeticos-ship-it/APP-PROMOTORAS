        "arquivoUrl": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["promotoraId", "dataEnvio"]
    },
    "config": {
      "title": "Configurações da Empresa",
      "description": "Configurações de integração ERP Bling e parâmetros do sistema",
      "type": "object",
      "properties": {
        "apiKey": { "type": "string" },
        "clientId": { "type": "string" },
        "statusConexao": { "type": "string" }
      },
      "required": ["statusConexao"]
