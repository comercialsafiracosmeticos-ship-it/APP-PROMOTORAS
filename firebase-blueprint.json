        "valor": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["numero", "clienteNome"]
    },
    "visitas": {
      "title": "Visitas e Auditorias PDV",
      "description": "Ponto eletrônico GPS, auditorias, fotos de fachada/display, produtos a vencer e concorrência",
