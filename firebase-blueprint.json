        "pecasVendidas": { "type": "number" }
      },
      "required": ["promotoraId", "clienteId"]
    },
    "escalas": {
      "title": "Escalas de Trabalho",
      "description": "Roteiro e agendamentos de visitas por promotora",
      "type": "object",
      "properties": {
        "promotoraId": { "type": "string" },
        "promotoraNome": { "type": "string" },
        "clienteId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "data": { "type": "string" },
