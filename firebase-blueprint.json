{
  "entities": {
    "promotoras": {
      "title": "Promotoras",
      "description": "Cadastro de promotoras e administradores de campo",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "codigoBling": { "type": "string" },
        "telefone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["nome", "role"]
    },
    "clientes": {
      "title": "Clientes",
      "description": "Lojas e pontos de venda parceiros",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "cnpj": { "type": "string" },
        "cidade": { "type": "string" },
        "endereco": { "type": "string" },
        "telefone": { "type": "string" },
        "faturamentoTotal": { "type": "number" }
      },
      "required": ["nome"]
    },
    "produtos": {
      "title": "Produtos",
      "description": "Catálogo de produtos e cosméticos",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "sku": { "type": "string" },
